@import url("https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&display=swap");

* {
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

body {
  font-family: "Oswald", sans-serif;
  background-color: hsl(0, 0%, 94%);
}

.form-container {
  max-width: 600px;
  margin: 50px auto;
  background-color: hsl(0, 0%, 100%);
  padding: 30px;
  border-radius: 8px;
  box-shadow: 1px 1px 10px hsl(0, 0%, 0%, 0.8);
}

h2 {
  text-align: center;
  margin-bottom: 20px;
}

fieldset {
  border: 1px solid hsl(0, 0%, 80%);
  border-radius: 5px;
  margin-bottom: 20px;
  padding: 20px;
}

legend {
  font-weight: bold;
  padding: 0 10px;
}

input[type="text"],
input[type="email"],
input[type="tel"],
select,
textarea {
  width: 100%;
  padding: 10px;
  margin: 6px 0 16px 0;
  border: 1px solid hsl(0, 0%, 80%);
  border-radius: 5px;
}

input[type="submit"] {
  background-color: hsl(0, 0%, 0%);
  color: hsl(0, 0%, 100%);
  padding: 12px 20px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  width: 100%;
  font-size: 16px;
  transition: 0.3s ease;
}

input[type="submit"]:hover {
  background-color: hsla(0, 0%, 0%, 0.8);
}

label {
  font-weight: bold;
}
