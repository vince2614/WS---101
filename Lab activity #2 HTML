<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
    />
    <link rel="stylesheet" href="style.css" />
    <title>John Vincent A. Mazo | Portfolio</title>
  </head>
  <body>
    <header>
      <nav class="nav-links">
        <div class="logo">Group 6.</div>
        <ul>
          <li><a href="#home" class="active">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contacts</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section id="about">
        <article>
          <h1>Mazo, John Vincent A.</h1>
          <p>
            I am a student at the Pateros Technological College, currently
            taking up Bachelor of Science in Information Technology. I am a 1st
            year student and I am currently in my 2nd semester. I am a
            hardworking and dedicated student who is always willing to learn new
            things. I am also a good communicator and I am always willing to
            share my knowledge with others.
          </p>
        </article>
      </section>

      <section class="register" id="register">
        <h2>Register Form</h2>
        <form action="#">
          <label for="username">Username</label>
          <input
            id="username"
            type="text"
            placeholder="Enter username"
            required
          />

          <label for="email">Email</label>
          <input id="email" type="email" placeholder="Enter email" required />

          <label for="password">Password</label>
          <input
            id="password"
            type="password"
            placeholder="Enter password"
            required
          />

          <button type="submit">Register</button>
        </form>
      </section>
    </main>

    <footer>
      <section id="contact">
        <div class="btn-social">
          <a href="#" class="btn">Contact Me</a>
          <div class="social">
            <a href="#"><i class="fa-brands fa-facebook"></i></a>
            <a href="#"><i class="fa-brands fa-tiktok"></i></a>
            <a href="#"><i class="fa-brands fa-github"></i></a>
          </div>
        </div>
      </section>
      &copy; Group6. All Rights Reserve
    </footer>
  </body>
</html>
